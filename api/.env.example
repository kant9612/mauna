# Database
DB_URL=jdbc:mysql://localhost:3306/mauna?useSSL=false&serverTimezone=Asia/Tokyo&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
DB_USERNAME=mauna_user
DB_PASSWORD=your_db_password_here

# JWT
JWT_SECRET=your-secret-key-change-this-in-production-minimum-256-bits
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080

# Logging
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN

# SMTP (if needed)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your_smtp_user
# SMTP_PASSWORD=your_smtp_password

# OAuth (if needed)
# OAUTH_CLIENT_ID=your_client_id
# OAUTH_CLIENT_SECRET=your_client_secret
